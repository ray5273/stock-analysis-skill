# Copy this file to .env.kiwoom and fill in your real Kiwoom REST API credentials.
KIWOOM_APP_KEY=your_app_key
KIWOOM_APP_SECRET=your_app_secret
KIWOOM_API_BASE_URL=https://api.kiwoom.com

# Legacy alias also accepted by the helper scripts:
# KIWOOM_SECRET_KEY=your_app_secret

# Optional: override if you installed kiwoom-mcp somewhere else.
KIWOOM_MCP_ENTRY=/tmp/kiwoom-mcp/dist/index.js
